APP_NAME=RelateOS API
DEBUG=true
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/relateos
REDIS_URL=redis://localhost:6379/0
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4o-mini
API_V1_PREFIX=/api/v1
CORS_ORIGINS=*
AUTO_CREATE_TABLES=true
AUTH_SECRET_KEY=replace-with-a-long-random-production-secret
AUTH_TOKEN_TTL_HOURS=168
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
FRONTEND_APP_URL=http://localhost:3000
RESEND_API_KEY=your_resend_api_key
AUTH_EMAIL_FROM="Teifke / Relationships <onboarding@resend.dev>"
ZOOM_WEBHOOK_SECRET_TOKEN=your_zoom_webhook_secret_token
ZOOM_OAUTH_CLIENT_ID=your_zoom_oauth_client_id
ZOOM_OAUTH_CLIENT_SECRET=your_zoom_oauth_client_secret
ZOOM_OAUTH_REDIRECT_URI=https://your-api-domain.com/api/v1/connections/zoom/oauth/callback
GOOGLE_CALENDAR_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CALENDAR_CLIENT_SECRET=your_google_oauth_client_secret
GOOGLE_CALENDAR_REDIRECT_URI=https://your-api-domain.com/api/v1/connections/google-calendar/oauth/callback
